---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: string;
  ogImage?: string;
  noindex?: boolean;
  active?: 'feed' | 'projects' | 'writing' | 'now' | 'about';
}

const { active, ...baseProps } = Astro.props;
---
<Base {...baseProps}>
  <slot name="head" slot="head" />

  <div class="ticker">
    <div class="wrap">
      <span class="live"><span class="dot"></span>Open to work</span>
      <span class="sep">/</span>
      <span class="hide-sm">Elizabeth, NJ</span>
      <span class="sep hide-sm">/</span>
      <span class="hide-sm">EST</span>
      <a class="right" href="mailto:busqueneil@gmail.com" style="color:inherit;text-decoration:none">busqueneil@gmail.com</a>
    </div>
  </div>

  <div class="wrap">
    <header class="masthead">
      <a class="name" href="/">busque<b>neil</b></a>
      <nav>
        <a href="/projects" aria-current={active === 'projects' ? 'page' : undefined}>Work</a>
        <a href="/feed" aria-current={active === 'feed' ? 'page' : undefined}>Feed</a>
        <a href="/posts" aria-current={active === 'writing' ? 'page' : undefined}>Writing</a>
        <a href="/now/" aria-current={active === 'now' ? 'page' : undefined}>Now</a>
        <a href="/about" aria-current={active === 'about' ? 'page' : undefined}>About</a>
        <a class="hire" href="/help">Hire</a>
      </nav>
    </header>

    <slot />

    <footer class="footer">
      <div class="footer-cols">
        <div class="footer-brand">busque<b>neil</b></div>
        <div class="footer-links">
          <a href="/projects">Work</a>
          <a href="/feed">Feed</a>
          <a href="/posts">Writing</a>
          <a href="/now/">Now</a>
          <a href="/about">About</a>
          <a href="/rss.xml">RSS</a>
          <a href="/resume.pdf">Resume</a>
          <a href="mailto:busqueneil@gmail.com">Email</a>
          <a href="https://www.linkedin.com/in/neilbusque/" rel="me">LinkedIn</a>
          <a href="https://github.com/neilbusque" rel="me">GitHub</a>
        </div>
      </div>
      <div class="footer-colophon">Built in public · Elizabeth, NJ · © 2026 Neil Busque</div>
    </footer>
  </div>
</Base>
