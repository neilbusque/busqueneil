---
import Base from '../layouts/Base.astro';
import Schema from '../components/Schema.astro';
import { setPublicCache } from '../lib/posts';
import '../styles/home-v6.css';

setPublicCache(Astro.response.headers);

const TECH = [
  'Claude Code', 'Next.js', 'Astro', 'React', 'TypeScript', 'Tailwind', 'Supabase',
  'Vercel', 'Cloudflare', 'n8n', 'Zapier', 'GoHighLevel', 'Stripe', 'Resend',
  'Three.js', 'WebRTC', 'Electron', 'PostgreSQL', 'Python', 'Node.js', 'GSAP',
];

// Museum pieces: 5 real screenshots + 2 "coming soon" pedestals.
const museum = [
  { name: 'Orbit', shot: '/assets/work/orbit.webp', url: 'https://www.inorbit.one', tag: 'AI CRM' },
  { name: 'Tandem', shot: '/assets/work/tandem.webp', url: 'https://tandem.yengandneil.site', tag: 'A private app for two' },
  { name: 'Otto', shot: '/assets/work/otto.webp', url: null, tag: 'Command center' },
  { name: 'Hop', shot: '/assets/work/hop.webp', url: 'https://links.busqueneil.com', tag: 'Link shortener' },
  { name: 'Play Together', shot: '/assets/work/play-together.webp', url: null, tag: 'Realtime games' },
  { name: 'Your app', shot: null, url: null, tag: 'This spot is open' },
  { name: 'Your site', shot: null, url: null, tag: 'This spot is open' },
];

const caps = [
  { t: 'Custom websites', d: 'Fast, clean sites built to convert, not just to look nice.' },
  { t: 'Web apps & PWAs', d: 'Full products, from a blank file to live, usually in days.' },
  { t: 'AI agents & systems', d: 'Assistants, SDRs, and copilots that actually do the job.' },
  { t: 'Automation', d: 'Zapier and n8n flows that quietly handle the repetitive work.' },
  { t: 'CRM & GoHighLevel', d: 'Pipelines and follow-up so leads stop slipping through.' },
  { t: 'Marketing & growth', d: 'SEO, paid search, and funnels that turn clicks into customers.' },
  { t: 'Design & brand', d: 'A graphic-design background, so the work looks the part too.' },
  { t: 'You own all of it', d: 'The code, the repo, the accounts. Never locked in a black box.' },
];

const testimonials = [
  { src: '/assets/testimonials/testimonial4.png', w: 814, h: 634, alt: 'Client praising 25 landing pages that outperformed and drove more leads and bookings' },
  { src: '/assets/testimonials/testimonial1.png', w: 1012, h: 202, alt: 'Client: You’re the man Neil, I already love working with you' },
  { src: '/assets/testimonials/testimonial8.png', w: 1132, h: 298, alt: 'Client testimonial about working with Neil Busque' },
  { src: '/assets/testimonials/testimonial3.png', w: 952, h: 260, alt: 'Client testimonial about working with Neil Busque' },
  { src: '/assets/testimonials/testimonial7.png', w: 1526, h: 254, alt: 'Client testimonial about working with Neil Busque' },
  { src: '/assets/testimonials/testimonial5.png', w: 864, h: 230, alt: 'Client testimonial about working with Neil Busque' },
  { src: '/assets/testimonials/testimonial2.png', w: 490, h: 130, alt: 'Client testimonial about working with Neil Busque' },
  { src: '/assets/testimonials/testimonial6.png', w: 482, h: 160, alt: 'Client testimonial about working with Neil Busque' },
];

const faqs = [
  { q: 'What if I do not like it?', a: 'We agree on what "done" looks like before I start, you see progress the whole way, and I keep working until it matches. You own the code either way, so you are never stuck with something you did not sign off on.' },
  { q: "Isn't AI-built software full of bugs?", a: 'Every app in the gallery above is live and in daily use, mine or a client’s. I build with tests, I use the thing myself before anyone else touches it, and I fix fast because I own the whole stack. AI writes code quicker. It does not skip the part where I make sure it works.' },
  { q: 'Why not just build it myself with Lovable or a no-code tool?', a: 'Go for it if it fits. Those tools are great right up until you need a real database, auth, billing, background jobs, or anything custom. That is the wall most people hit. I start where they stop, and you own the code instead of renting a platform.' },
  { q: "Can't I get the same thing out of ChatGPT myself?", a: 'You can get a prototype. Getting from a prototype to something that survives real users, payments, and edge cases is a different job. That gap is the part I get paid for.' },
  { q: 'How do you actually build this fast?', a: 'A stack I have shipped 50-plus times, modern AI tooling as my daily driver, and no committee. One person who has done it before moves faster than a team still arguing about which framework to use.' },
  { q: 'What happens if it breaks after you hand it off?', a: 'You get the code, the repo, and clear docs. Nothing is locked in a black box. I also stick around. Most people keep me on for tweaks and new features because it beats starting over, and one message reaches the person who built it.' },
];

const pad = (n: number) => String(n + 1).padStart(2, '0');
---
<Base
  title="Neil Busque: I turn your idea into a custom website or app, live in days"
  description="Bring me a rough idea. I design and build the custom website or web app around it, usually solo, usually in days. You own the code. Based in New Jersey."
  canonical="https://busqueneil.com/"
  ogType="profile"
  ogImage="https://busqueneil.com/assets/og-v5.png"
>
  <Fragment slot="head">
    <link rel="preload" as="image" href="/assets/art/neil-cutout.png" fetchpriority="high" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,600..700;1,9..144,600..700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Caveat:wght@600;700&display=swap" />
    <Schema />
  </Fragment>

  <div class="v6">
    <div class="page-cursor" id="pageCursor" aria-hidden="true"></div>
    <!-- scroll-growth vine (desktop) -->
    <div class="vine" id="vineProgress" aria-hidden="true">
      <span class="vine-stem"></span>
      <svg class="vine-tip" viewBox="0 0 24 24" fill="#1F9D55"><path d="M12 2C7 7 4 12 5 17c4 1 9-2 12-7 2-3 3-6 3-8-3 0-6 0-8 0z"/></svg>
    </div>

    <!-- nav -->
    <header class="nav">
      <div class="nav-inner">
        <a class="brand" href="/">busque<b>neil</b></a>
        <nav class="nav-links">
          <a href="#museum" class="nav-hide">Work</a>
          <a href="#capabilities" class="nav-hide">What I build</a>
          <a class="nav-cta" href="https://api.whatsapp.com/send/?phone=9083164140" target="_blank" rel="noopener">Get in touch</a>
        </nav>
      </div>
    </header>

    <!-- hero -->
    <section class="hero">
      <div class="shell">
        <div class="hero-inner">
          <div class="hero-copy">
            <p class="hero-kicker"><span class="dot"></span> Open for work · New Jersey</p>
            <h1 class="display">You plant the idea. <span class="hl">I grow it into something live.</span></h1>
            <p class="hero-sub">Bring me a <b>"we should build that"</b> and I turn it into a custom website or web app, with the <b>first working draft in about 5 days</b>. Built solo, built fast, and <b>you own all of it</b>.</p>
            <div class="hero-actions">
              <a class="btn primary" href="https://api.whatsapp.com/send/?phone=9083164140" target="_blank" rel="noopener">Tell me your idea <span class="ico">→</span></a>
              <a class="btn ghost" href="#process">Watch how it works</a>
            </div>
            <p class="hero-proof"><span class="tick">✦</span> Scroll to watch an idea become a shipped product.</p>
          </div>
          <div class="hero-visual" id="heroVisual">
            <img class="hero-grove" src="/assets/art/hero-grove.jpg" width="1100" height="1182" alt="" aria-hidden="true" fetchpriority="high" />
            <img class="hero-figure" src="/assets/art/neil-cutout.png" width="640" height="1413" alt="Neil Busque" fetchpriority="high" />
            <span class="hero-chip c1"><span class="ok">✓</span> shipped in 4 days</span>
            <span class="hero-chip c2"><span class="ok">✓</span> you own the repo</span>
          </div>
        </div>
      </div>
    </section>

    <!-- tech marquee -->
    <div class="marquee" aria-hidden="true">
      <div class="marquee-track">
        {[...TECH, ...TECH].map((t) => <span class="mq">{t}</span>)}
      </div>
    </div>

    <!-- process film -->
    <section class="film" id="process" data-film>
      <div class="film-pin">
        <!-- one dark sky: dawn glow + night stars crossfade, celestial wheel turns -->
        <div class="film-sky" aria-hidden="true">
          <div class="sky-layer sky-dawn"></div>
          <div class="sky-layer sky-night"></div>
          <div class="stars"></div>
          <div class="celestial" id="celestial">
            <span class="sun"></span>
            <span class="moon"></span>
          </div>
        </div>
        <div class="film-ground" aria-hidden="true"></div>

        <div class="film-hud">
          <p class="film-step"><span class="film-n" id="filmN">01</span> / 05</p>
          <p class="film-day" id="filmDay" hidden>Day 1</p>
        </div>

        <!-- the seed + the plant: persistent across beats, growing as days pass -->
        <div class="seed" id="filmSeed" aria-hidden="true"></div>
        <svg class="plant" id="filmPlant" viewBox="0 0 120 244" fill="none" aria-hidden="true">
          <ellipse class="soil" cx="62" cy="238" rx="26" ry="6" />
          <path class="stem" d="M62,236 C58,196 66,168 58,132 C52,104 62,76 58,44" />
          <path class="leaf lf1" d="M60,190 C40,184 28,168 30,150 C48,156 58,172 60,190 Z" />
          <path class="leaf lf2" d="M60,160 C80,152 90,136 88,120 C70,126 61,142 60,160 Z" />
          <path class="leaf lf3" d="M59,112 C41,106 32,92 34,76 C50,82 58,96 59,112 Z" />
          <circle class="bloom" cx="58" cy="40" r="12" />
        </svg>

        <div class="film-stage">
          <!-- beat 1: the idea -->
          <div class="beat" data-beat="1">
            <div class="note">"we should build that"</div>
          </div>

          <!-- beat 2: we talk it through -->
          <div class="beat" data-beat="2">
            <div class="callframe">
              <div class="call-tiles">
                <div class="tile you">
                  <span class="you-avatar">You</span>
                  <span class="who">You</span>
                  <span class="live-dot"></span>
                </div>
                <div class="tile me">
                  <img src="/assets/art/neilpic.png" alt="" width="500" height="750" loading="lazy" />
                  <span class="who">Neil</span>
                  <span class="live-dot"></span>
                </div>
              </div>
              <div class="call-bar" aria-hidden="true">
                <span>🎙</span><span>📷</span><span class="end">✕</span>
              </div>
            </div>
          </div>

          <!-- beat 3: building (laptop persists through the day cycle) -->
          <div class="beat beat-build" data-beat="3">
            <div class="laptop">
              <div class="lid">
                <span class="cam"></span>
                <div class="screen">
                  <div class="editor">
                    <div class="tab-bar"><i></i><i></i><i></i><span class="tab-name">your-idea.tsx · building</span></div>
                    <span class="cl"><span class="c-kw">import</span><span class="c-pl"> {'{ dream }'} </span><span class="c-kw">from</span><span class="c-str"> 'your-head'</span></span>
                    <span class="cl"><span class="c-com">// ok. let's make this real.</span></span>
                    <span class="cl"><span class="c-kw">const</span><span class="c-fn"> app</span><span class="c-pl"> = </span><span class="c-fn">build</span><span class="c-pl">(dream, {'{'}</span></span>
                    <span class="cl"><span class="c-pl">&nbsp;&nbsp;design: </span><span class="c-str">'yours'</span><span class="c-pl">,</span></span>
                    <span class="cl"><span class="c-pl">&nbsp;&nbsp;owner: </span><span class="c-str">'also yours'</span><span class="c-pl">,</span></span>
                    <span class="cl"><span class="c-pl">{'}'})</span></span>
                    <span class="cl"><span class="c-kw">await</span><span class="c-fn"> app</span><span class="c-pl">.</span><span class="c-fn">deploy</span><span class="c-pl">()</span><span class="c-com">  // → live</span></span>
                  </div>
                  <img class="ship-shot" src="/assets/work/orbit.webp" alt="" width="1280" height="800" loading="lazy" />
                </div>
              </div>
              <div class="deck"></div>
            </div>
          </div>

          <!-- beat 5: shipped -->
          <div class="beat beat-ship" data-beat="5">
            <div class="out">
              <div class="device-l"><img src="/assets/work/orbit.webp" alt="Custom web platform example" width="1280" height="800" loading="lazy" /></div>
              <span class="out-label">Your website</span>
            </div>
            <div class="out">
              <div class="device-p"><img src="/assets/work/tandem.webp" alt="Custom web app example" width="1280" height="800" loading="lazy" /></div>
              <span class="out-label">Your web app</span>
            </div>
            <span class="stamp">Shipped</span>
          </div>
        </div>

        <p class="film-caption" id="filmCaption" aria-hidden="true"></p>
      </div>

      <!-- static, readable version for mobile + reduced-motion -->
      <div class="film-fallback">
        <div class="shell">
          <p class="label"><span class="n">01</span> &nbsp;How it works</p>
          <h2 class="statement">Plant an idea. <span class="hl">Get a working draft in about 5 days.</span></h2>
          <ol class="film-steps">
            <li><span class="fs-n">01</span><p>Every product starts as a seed. Your "we should build that."</p></li>
            <li><span class="fs-n">02</span><p>We hop on one quick call and pick exactly what to grow.</p></li>
            <li><span class="fs-n">03</span><p>I plant it and get to work. Just me, heads down.</p></li>
            <li><span class="fs-n">04</span><p>First working draft in your hands in about 5 days. Not weeks.</p></li>
            <li><span class="fs-n">05</span><p>It grows into your web app. Or your site. Live, and yours.</p></li>
            <li><span class="fs-n">06</span><p>Then you review, we refine, and you get the playbook. Or we keep building together.</p></li>
          </ol>
        </div>
      </div>
    </section>

    <!-- after day 5 -->
    <div class="rule"></div>
    <section class="section after" id="after">
      <div class="shell">
        <div class="sec-head reveal">
          <div>
            <p class="label"><span class="n">02</span> &nbsp;After day 5</p>
            <h2>Day 5 is a draft, <span class="grad">not a goodbye.</span></h2>
          </div>
          <p class="lede">The first version is where the real work starts. Here is how it goes from draft to done, and what happens after.</p>
        </div>
        <div class="after-grid reveal">
          <div class="after-card">
            <span class="ac-n">01</span>
            <h3>You review it</h3>
            <p>You click through a real, working draft. You point at what feels off, what is missing, what you did not expect to want. Nothing is precious.</p>
          </div>
          <div class="after-card">
            <span class="ac-n">02</span>
            <h3>We shape and optimize</h3>
            <p>Fast rounds of changes until it feels right. Then the pass that pays for itself: speed, SEO, tracking, and the details that make it convert.</p>
          </div>
          <div class="after-card">
            <span class="ac-n">03</span>
            <h3>You choose how it grows</h3>
            <p>Full handoff with the repo, docs, and a written playbook for running it yourself. Or keep me on for the next features. Most people do both.</p>
          </div>
        </div>
        <p class="after-verdict reveal">Either way it is yours. The code, the accounts, the playbook. <b>You are never locked in. You just get to keep me if you want.</b></p>
      </div>
    </section>

    <!-- museum -->
    <section class="museum" id="museum" data-museum>
      <div class="shell museum-head">
        <div class="sec-head reveal">
          <div>
            <p class="label"><span class="n">03</span> &nbsp;The gallery</p>
            <h2>Step through a few of the builds.</h2>
          </div>
          <p class="lede">Real products, live and in use. Scroll sideways to walk the room, then open any piece to take a closer look.</p>
        </div>
      </div>
      <div class="museum-viewport">
        <div class="museum-track">
          {museum.map((p, i) => (
            <article
              class={`piece${p.shot ? '' : ' ghost'}`}
              data-full={p.shot ?? undefined}
              data-title={p.shot ? `${p.name} · ${p.tag}` : undefined}
              data-url={p.url ?? undefined}
            >
              <div class="spot" aria-hidden="true"></div>
              <div class="rig">
                <div class="mk">
                  <div class="mk-screen">
                    {p.shot
                      ? <img src={p.shot} alt={`${p.name} screenshot`} loading="lazy" width="1280" height="800" />
                      : <span class="soon">could be yours</span>}
                  </div>
                  <div class="mk-base" aria-hidden="true"></div>
                </div>
                <div class="pedestal" aria-hidden="true"></div>
              </div>
              <div class="piece-meta">
                <span class="piece-num">№ {pad(i)}</span>
                <span class="piece-name">{p.name}</span>
                <span class="piece-tag">{p.tag}</span>
                {p.shot && <button class="piece-open" type="button">View piece</button>}
              </div>
            </article>
          ))}
        </div>
      </div>

      <dialog class="museum-lightbox" id="museumLightbox">
        <button class="lb-close" id="lbClose" aria-label="Close">×</button>
        <div class="lb-inner">
          <img id="lbImg" alt="" />
          <div class="lb-meta">
            <h3 id="lbTitle"></h3>
            <a id="lbLink" class="btn ghost" target="_blank" rel="noopener" hidden>Visit live <span class="ico">↗</span></a>
          </div>
        </div>
      </dialog>
    </section>

    <!-- testimonials -->
    <section class="section testimonials" id="testimonials">
      <div class="shell">
        <div class="sec-head reveal">
          <div>
            <p class="label"><span class="n">04</span> &nbsp;Kind words</p>
            <h2>What it's like to work with me.</h2>
          </div>
          <p class="lede">Straight from clients and collaborators. Real messages, nothing edited.</p>
        </div>
        <div class="testi-grid reveal">
          {testimonials.map((t) => (
            <figure class="testi-card">
              <img src={t.src} alt={t.alt} width={t.w} height={t.h} loading="lazy" />
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- capabilities -->
    <div class="rule"></div>
    <section class="section" id="capabilities">
      <div class="shell">
        <p class="label sec-label reveal"><span class="n">05</span> &nbsp;What I build</p>
        <h2 class="statement reveal">From a landing page to <span class="hl">custom software you own.</span></h2>
        <div class="caps-grid reveal">
          {caps.map((c, i) => (
            <div class="cap-card">
              <span class="ci">{pad(i)}</span>
              <h3>{c.t}</h3>
              <p>{c.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- why me, not AI alone -->
    <div class="rule"></div>
    <section class="section why" id="why">
      <div class="shell">
        <div class="sec-head reveal">
          <div>
            <p class="label"><span class="n">06</span> &nbsp;Why me</p>
            <h2>Anyone can use AI. <span class="grad">That is not the job.</span></h2>
          </div>
          <p class="lede">AI gets you a demo in an afternoon. The last stretch, auth, payments, edge cases, design, deploys, is what decides whether real customers can use it. That is the part I sell.</p>
        </div>
        <div class="cmp-grid reveal">
          <div class="cmp-card cmp-bad">
            <p class="cmp-title">Using AI on your own</p>
            <ul>
              <li><span class="x">✕</span> A slick demo by Friday, stuck on auth and payments by Monday</li>
              <li><span class="x">✕</span> Prompting in circles every time something breaks</li>
              <li><span class="x">✕</span> Looks like every other AI template</li>
              <li><span class="x">✕</span> Nobody to call when it goes down</li>
            </ul>
          </div>
          <div class="cmp-card cmp-good">
            <p class="cmp-title">Working with me</p>
            <ul>
              <li><span class="ok">✓</span> 50+ live products shipped on this exact stack</li>
              <li><span class="ok">✓</span> Auth, billing, deploys, and the boring parts handled</li>
              <li><span class="ok">✓</span> A design background, so it looks like yours, not a template</li>
              <li><span class="ok">✓</span> First working draft in about 5 days, and you own the repo</li>
              <li><span class="ok">✓</span> One message reaches the person who built it, for good</li>
            </ul>
          </div>
        </div>
        <p class="cmp-verdict reveal">AI makes everyone fast. It does not make anything finished. <b>Finished is what you hire me for.</b></p>
      </div>
    </section>

    <!-- what do you want to build -->
    <div class="rule"></div>
    <section class="section build" id="build">
      <div class="shell">
        <p class="label reveal"><span class="n">07</span> &nbsp;Your turn</p>
        <h2 class="statement reveal">So, what do you want to build?</h2>
        <svg class="build-squiggle reveal" viewBox="0 0 260 22" fill="none" aria-hidden="true">
          <path d="M4,14 C44,3 78,21 120,11 C160,2 210,20 256,10" stroke="var(--v1)" stroke-width="4" stroke-linecap="round"/>
        </svg>
        <p class="build-sub reveal">Type it the way you would say it out loud. It goes straight to my phone, and we take it from there.</p>
        <form class="build-form reveal" id="buildForm">
          <div class="build-input-wrap">
            <svg class="input-sprout" id="inputSprout" viewBox="0 0 40 48" fill="none" aria-hidden="true">
              <path class="s-stem" d="M20,46 C19,36 22,30 20,20" stroke="#1F9D55" stroke-width="3" stroke-linecap="round"/>
              <path class="s-leaf" d="M20,30 C12,27 8,20 9,13 C16,16 20,22 20,30 Z" fill="#2F8F58"/>
              <path class="s-leaf2" d="M20,24 C28,21 32,14 31,7 C24,10 20,16 20,24 Z" fill="#1F9D55"/>
            </svg>
            <input id="buildInput" name="idea" type="text" autocomplete="off" placeholder="A booking app, a funnel, an AI assistant..." />
            <button class="btn primary" type="submit">Send it to me <span class="ico">→</span></button>
          </div>
          <div class="chips">
            <button type="button" class="chip" data-fill="I want to build a web app">Web app</button>
            <button type="button" class="chip" data-fill="I want a custom website">Website</button>
            <button type="button" class="chip" data-fill="I need an automation">Automation</button>
            <button type="button" class="chip" data-fill="I have an AI idea">AI agent</button>
            <button type="button" class="chip" data-fill="I have an idea but I am not sure yet">Not sure yet</button>
          </div>
        </form>
      </div>
    </section>

    <!-- faq -->
    <div class="rule"></div>
    <section class="section" id="faq">
      <div class="shell">
        <div class="sec-head reveal">
          <div>
            <p class="label"><span class="n">08</span> &nbsp;Straight answers</p>
            <h2>The questions everyone asks first.</h2>
          </div>
          <p class="lede">You're probably thinking one of these. Here's the honest version.</p>
        </div>
        <div class="faq-list reveal">
          {faqs.map((f) => (
            <details class="faq-item">
              <summary>
                <span class="faq-q">{f.q}</span>
                <span class="faq-ico" aria-hidden="true">+</span>
              </summary>
              <p class="faq-a">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- contact -->
    <section class="section hire-band" id="contact">
      <img class="hire-art" src="/assets/art/grove-band.jpg" alt="" width="2400" height="1028" loading="lazy" />
      <div class="shell">
        <div class="contact-grid reveal">
          <div class="contact-copy">
