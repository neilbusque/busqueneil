---
import Base from '../layouts/Base.astro';
import Schema from '../components/Schema.astro';
import { setPublicCache } from '../lib/posts';
import '../styles/home.css';

setPublicCache(Astro.response.headers);

const projects = [
  { name: 'Orbit', desc: 'A simple AI-powered CRM. Pipelines, a shared inbox, billing, and an assistant that drafts replies and books calls.', chips: ['Next.js', 'Supabase', 'AI agent'], url: 'https://app.inorbit.one', label: 'app.inorbit.one' },
  { name: 'Otto', desc: 'An autonomous command center. A CRM whose AI reads email, follows up, and moves deals while I am away.', chips: ['Next 14', 'Claude', 'Gmail API'], url: 'https://otto-neilbusque.vercel.app', label: 'otto-neilbusque.vercel.app' },
  { name: 'Magus', desc: 'Cold email plus an AI SDR. It writes, sends, calls, and books, then hands you a calendar that fills itself.', chips: ['Supabase', 'Vapi', 'Cal.com'], url: 'https://magus.neilb.me', label: 'magus.neilb.me' },
  { name: 'Pulse', desc: 'A personal trends radar. It watches the web all day and emails me the signal worth acting on each morning.', chips: ['PWA', 'Cron', 'Resend'], url: 'https://trends.neilb.me', label: 'trends.neilb.me' },
  { name: 'Hop', desc: 'A link shortener with teeth. Real-time analytics, web push, a PWA, and a Chrome extension.', chips: ['Edge', 'Web Push', 'Extension'], url: 'https://links.busqueneil.com', label: 'links.busqueneil.com' },
  { name: 'Prism', desc: 'A Mac browser for people with ten logins. Separate profiles, an ad blocker, and a built-in AI panel.', chips: ['Electron', 'Chromium', 'AI panel'], url: null, label: 'macOS desktop app' },
  { name: 'Tandem', desc: 'A private app for two. Shared habits, letters, games, and watch parties, all in one quiet hub.', chips: ['PWA', 'Supabase', 'Realtime'], url: 'https://hub.yengandneil.site', label: 'hub.yengandneil.site' },
  { name: 'Play Together', desc: 'Watch anything together. One-to-one video calls that share tab audio and stay perfectly in sync.', chips: ['WebRTC', 'TURN', 'Extension'], url: 'https://watch.yengandneil.site', label: 'watch.yengandneil.site' },
];

const pad = (n: number) => String(n + 1).padStart(2, '0');
---
<Base
  title="Neil Busque — I build the AI that ships"
  description="Anyone can call the API. Neil Busque builds the system around it: AI agents, automation, full web apps, and the growth engine they serve. A deep AI and IT background, eight live products. Based in New Jersey. Open to work, including fractional CTO and Head of AI."
  canonical="https://busqueneil.com/"
  ogType="profile"
  ogImage="https://busqueneil.com/assets/art/hero.png"
  dark
>
  <Fragment slot="head">
    <Schema />
  </Fragment>

  <div class="home-v4">
    <!-- nav -->
    <header class="nav">
      <div class="nav-inner">
        <a class="brand" href="/"><span class="mk">N</span>busqueneil</a>
        <nav class="nav-links">
          <a href="#work" class="nav-hide">Work</a>
          <a href="#about" class="nav-hide">About</a>
          <a href="/feed" class="nav-hide">Feed</a>
          <a class="nav-cta" href="#hire">Hire me</a>
        </nav>
      </div>
    </header>

    <!-- hero -->
    <section class="hero">
      <div class="hero-art">
        <img src="/assets/art/hero.png" alt="" width="2560" height="1440" fetchpriority="high" />
      </div>
      <div class="hero-services">
        <span>AI Systems</span>
        <span>Automation</span>
        <span>Web Apps</span>
        <span>Growth Engineering</span>
      </div>
      <div class="hero-inner">
        <p class="label hero-eyebrow"><span class="n">●</span> Open to work · New Jersey</p>
        <h1 class="display"><span class="muted">Anyone can call the API.</span><br />I build the system.</h1>
        <p class="hero-sub">
          I'm Neil. I've spent my career deep in AI and IT, and I ship production
          systems the way most people ship slide decks. Eight live products, most
          built in days.
        </p>
        <div class="hero-actions">
          <a class="btn primary" href="#hire">Hire me <span class="ico">→</span></a>
          <a class="btn ghost" href="#work">See the work</a>
        </div>
      </div>
    </section>

    <!-- about -->
    <div class="rule"></div>
    <section class="section" id="about">
      <div class="shell">
        <p class="label sec-label reveal"><span class="n">01</span> &nbsp;About</p>
        <h2 class="statement reveal">The demo is easy. <span class="muted">Everything around it is the job.</span></h2>
        <div class="about-grid reveal">
          <div>
            <p>
              I came up through IT and never left the deep end of it. When AI
              stopped being a novelty and became infrastructure, I was already
              building with it every day, not reading about it.
            </p>
            <p>
              The pattern I keep seeing: the AI core, the prompts, the basic RAG,
              the API calls, is the easy twenty percent. Anyone can build it. The
              real work is everything around the model, the routing, the data, the
              automation, the parts that decide whether it survives real users.
              <strong>That is the part I own.</strong>
            </p>
          </div>
          <div>
            <p>
              I build independently and fast. Eight products are live, most shipped
              within days of the idea, and I post the work in public on
              <a href="/feed">the feed</a> as it happens.
            </p>
            <p>
              I grew up in the Philippines, spent years in Korea, and now work from
              New Jersey. I care about one thing whether I am writing a prompt or a
              landing page: does it work, and does it keep working without me
              standing over it.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- how I think -->
    <section class="section" id="how" style="padding-top:0">
      <div class="shell">
        <div class="think reveal">
          <div class="blk">
            <span class="num">01</span>
            <h3>Systems, not wrappers</h3>
            <p>A nice UI over an API call is not a product. I build the routing, the data, the automation, and the observability that make AI hold up in production.</p>
          </div>
          <div class="blk">
            <span class="num">02</span>
            <h3>Shipped, not theorized</h3>
            <p>I learn by deploying. Eight products are live because I build the thing instead of planning the thing. Most of it ships in days, not quarters.</p>
          </div>
          <div class="blk">
            <span class="num">03</span>
            <h3>Built to move a number</h3>
            <p>I came up through marketing and growth, so I build software that moves something real: leads, conversions, revenue. The tech serves the outcome.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- what I don't do -->
    <div class="rule"></div>
    <section class="section" id="dont">
      <div class="shell">
        <div class="dont reveal">
          <div>
            <p class="label"><span class="n">02</span> &nbsp;Boundaries</p>
            <h2>What I don't do.</h2>
          </div>
          <div class="dont-list">
            <div class="item"><span class="x">/</span><p><b>I don't ship AI wrappers dressed up as products.</b> A core API call with a nice interface is not a system, and I won't pretend it is one.</p></div>
            <div class="item"><span class="x">/</span><p><b>I don't build for the sake of building.</b> If it doesn't move a number you care about, it doesn't ship.</p></div>
            <div class="item"><span class="x">/</span><p><b>I don't take off-the-shelf work.</b> If the answer is one search away, you don't need me for it, and I'll tell you so.</p></div>
          </div>
        </div>
      </div>
    </section>

    <!-- generated art strip -->
    <div class="rule"></div>
    <section class="section" id="art">
      <div class="shell">
        <p class="label sec-label reveal"><span class="n">03</span> &nbsp;Generated in-house</p>
        <h2 class="statement reveal" style="font-size:clamp(24px,3.4vw,42px);max-width:24ch">Every visual here, including the art, I generated and built myself.</h2>
        <div class="art-strip reveal" style="margin-top:44px">
          <figure><img src="/assets/art/neural.png" alt="Generated obsidian neural mesh" loading="lazy" /><figcaption>Neural mesh</figcaption></figure>
          <figure><img src="/assets/art/terrain.png" alt="Generated obsidian terrain" loading="lazy" /><figcaption>Obsidian terrain</figcaption></figure>
          <figure><img src="/assets/art/topo.png" alt="Generated contour field" loading="lazy" /><figcaption>Contour field</figcaption></figure>
        </div>
      </div>
    </section>

    <!-- work -->
    <div class="rule"></div>
    <section class="section" id="work">
      <div class="shell">
        <div class="sec-head reveal">
          <div>
            <p class="label"><span class="n">04</span> &nbsp;Selected work</p>
            <h2>Eight products. All mine, end to end.</h2>
          </div>
          <p class="lede">Not slide decks. Live software you can open right now. Each one taken from idea to deployed, usually solo.</p>
        </div>
        <div class="work-grid reveal">
          {projects.map((p, i) => {
            const Tag = p.url ? 'a' : 'div';
            return (
              <Tag class="work-card" href={p.url ?? undefined} rel={p.url ? 'noopener' : undefined} target={p.url ? '_blank' : undefined}>
                <div class="top">
                  <span class="pname">{p.name}</span>
                  <span class="idx">{p.url ? '↗' : pad(i)}</span>
                </div>
                <p class="pdesc">{p.desc}</p>
                <div class="chips">{p.chips.map((c) => <span class="chip">{c}</span>)}</div>
                <div class="liveurl">{p.label}</div>
              </Tag>
            );
          })}
          <a class="work-card more" href="/feed">
            <div class="top"><span class="pname">More</span><span class="idx">↗</span></div>
            <p class="pdesc">I ship something most weeks. The full build log, posted in public as it happens, lives on the feed.</p>
            <div class="liveurl">busqueneil.com/feed</div>
          </a>
        </div>
      </div>
    </section>

    <!-- hire -->
    <div class="rule"></div>
    <section class="section" id="hire">
      <div class="shell">
        <div class="hire reveal">
          <p class="label" style="justify-content:center"><span class="n">05</span> &nbsp;Open for work</p>
          <h2>Hire me to own where AI meets the business.</h2>
          <p>
            Open to full-time roles across digital marketing, SEO, and paid search,
            and built to take the senior seat where AI, automation, and product
            live. Bring me in as the person who owns it, end to end.
          </p>
          <div class="roles">
            <span class="role">Fractional CTO</span>
            <span class="role">Head of AI</span>
            <span class="role">AI Systems Architect</span>
            <span class="role">Growth / Marketing Lead</span>
            <span class="role">Automation Engineer</span>
          </div>
          <div class="hire-actions">
            <a class="btn primary" href="mailto:busqueneil@gmail.com">Email me <span class="ico">→</span></a>
            <a class="btn ghost" href="https://www.linkedin.com/in/neilbusque/" rel="me noopener" target="_blank">LinkedIn</a>
            <a class="btn ghost" href="/resume.pdf">Resume</a>
          </div>
        </div>
      </div>
    </section>

    <!-- talk -->
    <section class="section" id="talk" style="padding-top:0">
      <div class="shell">
        <div class="talk reveal">
          <div class="l">
            <h2>Or just talk to me, live.</h2>
            <p>Skip the form. Start a video call and we'll know in a few minutes if I'm the person you've been trying to hire.</p>
          </div>
          <a class="btn primary" href="https://talk.busqueneil.com" rel="noopener" target="_blank">Start a live call <span class="ico">→</span></a>
        </div>
      </div>
    </section>

    <!-- footer -->
    <footer class="v4-footer">
      <div class="fin">
        <div class="ftop">
          <a class="fbrand" href="/">busqueneil</a>
          <div class="flinks">
            <a href="#work">Work</a>
            <a href="/feed">Feed</a>
            <a href="/posts">Writing</a>
            <a href="/now/">Now</a>
            <a href="/about">About</a>
            <a href="/resume.pdf">Resume</a>
            <a href="mailto:busqueneil@gmail.com">Email</a>
            <a href="https://www.linkedin.com/in/neilbusque/" rel="me noopener" target="_blank">LinkedIn</a>
            <a href="https://github.com/neilbusque" rel="me noopener" target="_blank">GitHub</a>
          </div>
        </div>
        <div class="colophon">Built in public · New Jersey · © 2026 Neil Busque</div>
      </div>
    </footer>
  </div>

  <script is:inline src="https://talk.busqueneil.com/widget.js" async></script>
</Base>
