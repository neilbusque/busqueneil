---
import Base from '../layouts/Base.astro';
import Schema from '../components/Schema.astro';
import { setPublicCache } from '../lib/posts';
import '../styles/home-v6.css';

setPublicCache(Astro.response.headers);

// Museum pieces: 5 real screenshots + 2 "coming soon" pedestals.
const museum = [
  { name: 'Orbit', shot: '/assets/work/orbit.webp', url: 'https://www.inorbit.one', tag: 'AI CRM' },
  { name: 'Tandem', shot: '/assets/work/tandem.webp', url: 'https://tandem.yengandneil.site', tag: 'A private app for two' },
  { name: 'Otto', shot: '/assets/work/otto.webp', url: null, tag: 'Command center' },
  { name: 'Hop', shot: '/assets/work/hop.webp', url: 'https://links.busqueneil.com', tag: 'Link shortener' },
  { name: 'Play Together', shot: '/assets/work/play-together.webp', url: null, tag: 'Realtime games' },
  { name: 'Your app', shot: null, url: null, tag: 'Coming soon' },
  { name: 'Your site', shot: null, url: null, tag: 'Coming soon' },
];

const caps = [
  { t: 'Custom websites', d: 'Fast, clean sites built to convert, not just to look nice.' },
  { t: 'Web apps & PWAs', d: 'Full products, from a blank file to live, usually in days.' },
  { t: 'AI agents & systems', d: 'Assistants, SDRs, and copilots that actually do the job.' },
  { t: 'Automation', d: 'Zapier and n8n flows that quietly handle the repetitive work.' },
  { t: 'CRM & GoHighLevel', d: 'Pipelines and follow-up so leads stop slipping through.' },
  { t: 'Marketing & growth', d: 'SEO, paid search, and funnels that turn clicks into customers.' },
  { t: 'Design & brand', d: 'A graphic-design background, so the work looks the part too.' },
  { t: 'You own all of it', d: 'The code, the repo, the accounts. Never locked in a black box.' },
];

const testimonials = [
  { src: '/assets/testimonials/testimonial4.png', w: 814, h: 634, alt: 'Client praising 25 landing pages that outperformed and drove more leads and bookings' },
  { src: '/assets/testimonials/testimonial1.png', w: 1012, h: 202, alt: 'Client: You’re the man Neil, I already love working with you' },
  { src: '/assets/testimonials/testimonial8.png', w: 1132, h: 298, alt: 'Client testimonial about working with Neil Busque' },
  { src: '/assets/testimonials/testimonial3.png', w: 952, h: 260, alt: 'Client testimonial about working with Neil Busque' },
  { src: '/assets/testimonials/testimonial7.png', w: 1526, h: 254, alt: 'Client testimonial about working with Neil Busque' },
  { src: '/assets/testimonials/testimonial5.png', w: 864, h: 230, alt: 'Client testimonial about working with Neil Busque' },
  { src: '/assets/testimonials/testimonial2.png', w: 490, h: 130, alt: 'Client testimonial about working with Neil Busque' },
  { src: '/assets/testimonials/testimonial6.png', w: 482, h: 160, alt: 'Client testimonial about working with Neil Busque' },
];

const faqs = [
  { q: 'What if I do not like it?', a: 'We agree on what "done" looks like before I start, you see progress the whole way, and I keep working until it matches. You own the code either way, so you are never stuck with something you did not sign off on.' },
  { q: "Isn't AI-built software full of bugs?", a: 'Every app in the gallery above is live and in daily use, mine or a client’s. I build with tests, I use the thing myself before anyone else touches it, and I fix fast because I own the whole stack. AI writes code quicker. It does not skip the part where I make sure it works.' },
  { q: 'Why not just build it myself with Lovable or a no-code tool?', a: 'Go for it if it fits. Those tools are great right up until you need a real database, auth, billing, background jobs, or anything custom. That is the wall most people hit. I start where they stop, and you own the code instead of renting a platform.' },
  { q: "Can't I get the same thing out of ChatGPT myself?", a: 'You can get a prototype. Getting from a prototype to something that survives real users, payments, and edge cases is a different job. That gap is the part I get paid for.' },
  { q: 'How do you actually build this fast?', a: 'A stack I have shipped 50-plus times, modern AI tooling as my daily driver, and no committee. One person who has done it before moves faster than a team still arguing about which framework to use.' },
  { q: 'What happens if it breaks after you hand it off?', a: 'You get the code, the repo, and clear docs. Nothing is locked in a black box. I also stick around. Most people keep me on for tweaks and new features because it beats starting over, and one message reaches the person who built it.' },
];

const pad = (n: number) => String(n + 1).padStart(2, '0');
---
<Base
  title="Neil Busque: I turn your idea into a custom website or app, live in days"
  description="Bring me a rough idea. I design and build the custom website or web app around it, usually solo, usually in days. You own the code. Based in New Jersey."
  canonical="https://busqueneil.com/"
  ogType="profile"
  ogImage="https://busqueneil.com/assets/og-v5.png"
  dark
>
  <Fragment slot="head">
    <link rel="preload" as="image" href="/assets/art/neil-hero.webp" fetchpriority="high" />
    <Schema />
  </Fragment>

  <div class="v6">
    <div class="page-cursor" id="pageCursor" aria-hidden="true"></div>

    <!-- nav -->
    <header class="nav">
      <div class="nav-inner">
        <a class="brand" href="/">busque<b>neil</b></a>
        <nav class="nav-links">
          <a href="#museum" class="nav-hide">Work</a>
          <a href="#capabilities" class="nav-hide">What I build</a>
          <a class="nav-cta" href="https://api.whatsapp.com/send/?phone=9083164140" target="_blank" rel="noopener">Get in touch</a>
        </nav>
      </div>
    </header>

    <!-- hero -->
    <section class="hero">
      <div class="shell">
        <div class="hero-inner">
          <div class="hero-copy">
            <h1 class="display">Bring me a <span class="hl">“we should build that.”</span><span class="accent">I turn it into a custom website or app, live in days. You own all of it.</span></h1>
            <div class="hero-actions">
              <a class="btn primary" href="https://api.whatsapp.com/send/?phone=9083164140" target="_blank" rel="noopener">Tell me what you want to build <span class="ico">→</span></a>
              <p class="cta-note">Straight to my phone. No pitch, just say hi.</p>
            </div>
            <p class="hero-proof"><span class="tick">✓</span> Scroll to watch an idea become a shipped product.</p>
          </div>
          <div class="hero-visual" id="heroVisual">
            <video class="hero-figure" autoplay muted loop playsinline poster="/assets/art/neil-hero.webp" width="900" height="1200" aria-label="Animated 3D illustration of Neil Busque building software">
              <source src="/assets/art/neil-hero.mp4" type="video/mp4" />
            </video>
          </div>
        </div>
      </div>
    </section>

    <!-- process film -->
    <section class="film" id="process" data-film>
      <div class="film-pin">
        <!-- day/night sky (two crossfading layers + a rotating celestial wheel) -->
        <div class="film-sky" aria-hidden="true">
          <div class="sky-layer sky-day"></div>
          <div class="sky-layer sky-night"></div>
          <div class="celestial" id="celestial">
            <span class="sun"></span>
            <span class="moon"></span>
          </div>
        </div>

        <div class="film-hud">
          <p class="film-step"><span class="film-n" id="filmN">01</span> / 05</p>
          <p class="film-day" id="filmDay" hidden>Day 1</p>
        </div>

        <div class="film-stage">
          <!-- beat 1: the idea -->
          <div class="beat" data-beat="1">
            <svg class="scribble" id="filmScribble" viewBox="0 0 420 200" fill="none" aria-hidden="true">
              <path d="M24,150 C70,60 120,52 156,118 C182,166 214,168 244,104 C268,54 320,44 356,96 C378,128 392,120 404,92"
                stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
            </svg>
            <div class="note">we should build that</div>
          </div>

          <!-- beat 2: we talk it through -->
          <div class="beat" data-beat="2">
            <div class="callframe">
              <div class="tile you"><span class="av">You</span><span class="live-dot"></span></div>
              <div class="tile me"><span class="av">Neil</span><span class="live-dot"></span></div>
            </div>
            <p class="beat-tag">a quick call, virtually</p>
          </div>

          <!-- beat 3: building (laptop persists through the day cycle) -->
          <div class="beat beat-build" data-beat="3">
            <div class="laptop">
              <div class="lid">
                <div class="code">
                  <span class="ln"></span><span class="ln"></span><span class="ln"></span>
                  <span class="ln"></span><span class="ln"></span><span class="ln"></span>
                </div>
              </div>
              <div class="deck"></div>
            </div>
          </div>

          <!-- beat 5: shipped -->
          <div class="beat beat-ship" data-beat="5">
            <div class="out out-site">
              <div class="browser"><span class="dot"></span><span class="dot"></span><span class="dot"></span></div>
              <span class="out-label">3D website</span>
            </div>
            <div class="out out-app">
              <div class="phone"></div>
              <span class="out-label">Web app</span>
            </div>
            <span class="stamp">Shipped</span>
          </div>
        </div>

        <p class="film-caption" id="filmCaption" aria-hidden="true"></p>
      </div>

      <!-- static, readable version for mobile + reduced-motion -->
      <div class="film-fallback">
        <div class="shell">
          <p class="label"><span class="n">✳</span> &nbsp;How it works</p>
          <h2 class="statement">From a scribble to something you own, in about a week.</h2>
          <ol class="film-steps">
            <li><span class="fs-n">01</span><p>It starts as a scribble. "We should build that."</p></li>
            <li><span class="fs-n">02</span><p>We hop on a quick call and nail down what it actually is.</p></li>
            <li><span class="fs-n">03</span><p>I build it. Just me, heads down.</p></li>
            <li><span class="fs-n">04</span><p>Days pass. Sun up, sun down, sun up.</p></li>
            <li><span class="fs-n">05</span><p>You get it back. A site and an app you own, live.</p></li>
          </ol>
        </div>
      </div>
    </section>

    <!-- museum -->
    <div class="rule"></div>
    <section class="museum" id="museum" data-museum>
      <div class="shell museum-head">
        <div class="sec-head reveal">
          <div>
            <p class="label"><span class="n">✳</span> &nbsp;The gallery</p>
            <h2>Step through a few of the builds.</h2>
          </div>
          <p class="lede">Real products, live and in use. Scroll sideways to walk the room, then open any piece to take a closer look.</p>
        </div>
      </div>
      <div class="museum-viewport">
        <div class="museum-track">
          {museum.map((p) => (
            <article
              class={`piece${p.shot ? '' : ' ghost'}`}
              data-full={p.shot ?? undefined}
              data-title={p.shot ? `${p.name} · ${p.tag}` : undefined}
              data-url={p.url ?? undefined}
            >
              <div class="spot" aria-hidden="true"></div>
              <div class="rig">
                <div class="mk">
                  <div class="mk-screen">
                    {p.shot
                      ? <img src={p.shot} alt={`${p.name} screenshot`} loading="lazy" width="1280" height="800" />
                      : <span class="soon">Coming soon</span>}
                  </div>
                  <div class="mk-base" aria-hidden="true"></div>
                </div>
                <div class="pedestal" aria-hidden="true"></div>
              </div>
              <div class="piece-meta">
                <span class="piece-name">{p.name}</span>
                <span class="piece-tag">{p.tag}</span>
                {p.shot && <button class="piece-open" type="button">View <span aria-hidden="true">↗</span></button>}
              </div>
            </article>
          ))}
        </div>
      </div>

      <dialog class="museum-lightbox" id="museumLightbox">
        <button class="lb-close" id="lbClose" aria-label="Close">×</button>
        <div class="lb-inner">
          <img id="lbImg" alt="" />
          <div class="lb-meta">
            <h3 id="lbTitle"></h3>
            <a id="lbLink" class="btn ghost" target="_blank" rel="noopener" hidden>Visit live <span class="ico">↗</span></a>
          </div>
        </div>
      </dialog>
    </section>

    <!-- testimonials -->
    <div class="rule"></div>
    <section class="section testimonials" id="testimonials">
      <div class="shell">
        <div class="sec-head reveal">
          <div>
            <p class="label"><span class="n">✳</span> &nbsp;Kind words</p>
            <h2>What it's like to work with me.</h2>
          </div>
          <p class="lede">Straight from clients and collaborators. Real messages, nothing edited.</p>
        </div>
        <div class="testi-grid reveal">
          {testimonials.map((t) => (
            <figure class="testi-card">
              <img src={t.src} alt={t.alt} width={t.w} height={t.h} loading="lazy" />
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- capabilities -->
    <div class="rule"></div>
    <section class="section" id="capabilities">
      <div class="shell">
        <p class="label sec-label reveal"><span class="n">✳</span> &nbsp;What I build</p>
        <h2 class="statement reveal">From a landing page to custom software you own.</h2>
        <div class="caps-grid reveal">
          {caps.map((c, i) => (
            <div class="cap-card">
              <span class="ci">{pad(i)}</span>
              <h3>{c.t}</h3>
              <p>{c.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- what do you want to build -->
    <div class="rule"></div>
    <section class="section build" id="build">
      <div class="shell">
        <p class="label reveal"><span class="n">✳</span> &nbsp;Your turn</p>
        <h2 class="statement reveal">So, what do you want to build?</h2>
        <svg class="build-squiggle reveal" viewBox="0 0 260 22" fill="none" aria-hidden="true">
          <path d="M4,14 C44,3 78,21 120,11 C160,2 210,20 256,10" stroke="var(--v1)" stroke-width="4" stroke-linecap="round"/>
        </svg>
        <p class="build-sub reveal">Type it the way you would say it out loud. It goes straight to my phone, and we take it from there.</p>
        <form class="build-form reveal" id="buildForm">
          <div class="build-input-wrap">
            <input id="buildInput" name="idea" type="text" autocomplete="off" placeholder="A booking app, a funnel, an AI assistant..." />
            <button class="btn primary" type="submit">Send it to me <span class="ico">→</span></button>
          </div>
          <div class="chips">
            <button type="button" class="chip" data-fill="I want to build a web app">Web app</button>
            <button type="button" class="chip" data-fill="I want a custom website">Website</button>
            <button type="button" class="chip" data-fill="I need an automation">Automation</button>
            <button type="button" class="chip" data-fill="I have an AI idea">AI agent</button>
            <button type="button" class="chip" data-fill="I have an idea but I am not sure yet">Not sure yet</button>
          </div>
        </form>
      </div>
    </section>

    <!-- faq -->
    <div class="rule"></div>
    <section class="section" id="faq">
      <div class="shell">
        <div class="sec-head reveal">
          <div>
            <p class="label"><span class="n">✳</span> &nbsp;Straight answers</p>
            <h2>Why me, and not the tools yourself.</h2>
          </div>
          <p class="lede">You're probably thinking one of these. Here's the honest version.</p>
        </div>
        <div class="faq-list reveal">
          {faqs.map((f) => (
            <details class="faq-item">
              <summary>
                <span class="faq-q">{f.q}</span>
                <span class="faq-ico" aria-hidden="true">+</span>
              </summary>
              <p class="faq-a">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- contact -->
    <div class="rule"></div>
    <section class="section hire-band" id="contact">
      <img class="hire-art" src="/assets/art/terrain.png" alt="" loading="lazy" />
      <div class="shell">
        <div class="contact-grid reveal">
          <div class="contact-copy">
            <p class="label"><span class="n">✳</span> &nbsp;Let's build it</p>
            <h2>Bring me the idea you keep putting off.</h2>
            <p class="pitch">Full-time, fractional, or a one-off project. I'll own the part where design, marketing, automation, and AI come together, and turn your idea into something live and yours.</p>
            <div class="roles">
              <span class="role">Custom websites</span>
              <span class="role">Web apps &amp; PWAs</span>
              <span class="role">AI agents</span>
              <span class="role">Automation</span>
              <span class="role">Fractional builder</span>
            </div>
            <div class="alt-contact">
              <a href="https://api.whatsapp.com/send/?phone=9083164140" rel="noopener" target="_blank">WhatsApp</a>
              <a href="mailto:busqueneil@gmail.com">busqueneil@gmail.com</a>
              <a href="https://www.linkedin.com/in/neilbusque/" rel="me noopener" target="_blank">LinkedIn</a>
              <a href="/resume.pdf">Resume</a>
            </div>
          </div>
          <div class="lead-card">
            <h3 class="lc-title">Just send me a DM</h3>
            <p class="lc-sub">No form, no pitch, no pressure. Message me on WhatsApp and we'll talk like people.</p>
            <ul class="lc-perks">
              <li><span class="tick">✓</span> Hop on a quick call and you'll walk away with something useful.</li>
              <li><span class="tick">✓</span> I'll send you a free tool you can start using right away.</li>
            </ul>
            <a class="btn primary" href="https://api.whatsapp.com/send/?phone=9083164140" rel="noopener" target="_blank">Message me on WhatsApp <span class="ico">→</span></a>
            <p class="form-note">Straight to my phone. Just say hi.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- footer -->
    <footer class="v6-footer">
      <div class="fin">
        <div class="ftop">
          <a class="fbrand" href="/">busque<b>neil</b></a>
          <div class="flinks">
            <a href="#museum">Work</a>
            <a href="/about">About</a>
            <a href="/resume.pdf">Resume</a>
            <a href="mailto:busqueneil@gmail.com">Email</a>
            <a href="https://www.linkedin.com/in/neilbusque/" rel="me noopener" target="_blank">LinkedIn</a>
          </div>
        </div>
        <div class="colophon">Built in public · New Jersey · © 2026 Neil Busque</div>
      </div>
    </footer>
  </div>

  <script>
    import '../scripts/home-v6.ts';
  </script>
</Base>
