---
import Base from '../layouts/Base.astro';
import Schema from '../components/Schema.astro';
import VoiceWidget from '../components/VoiceWidget.tsx';
import { setPublicCache } from '../lib/posts';
import '../styles/home.css';

const TECH = [
  'Claude Code', 'Next.js', 'Astro', 'React', 'TypeScript', 'Tailwind', 'Supabase',
  'Vercel', 'Cloudflare', 'n8n', 'Zapier', 'GoHighLevel', 'OpenRouter', 'Stripe',
  'Resend', 'Three.js', 'WebRTC', 'Electron', 'PostgreSQL', 'Python', 'Node.js',
];

setPublicCache(Astro.response.headers);

const projects = [
  { name: 'Orbit', desc: 'A simple AI-powered CRM. Pipelines, a shared inbox, billing, and an assistant that drafts replies and books calls.', chips: ['Next.js', 'Supabase', 'AI agent'], url: 'https://app.inorbit.one', label: 'app.inorbit.one' },
  { name: 'Otto', desc: 'An autonomous command center. A CRM whose AI reads my email, follows up, and moves deals while I am away.', chips: ['Next 14', 'Claude', 'Gmail API'], url: 'https://otto-neilbusque.vercel.app', label: 'otto-neilbusque.vercel.app' },
  { name: 'Magus', desc: 'Cold email plus an AI SDR. It writes, sends, calls, and books, then hands you a calendar that fills itself.', chips: ['Supabase', 'Vapi', 'Cal.com'], url: 'https://magus.neilb.me', label: 'magus.neilb.me' },
  { name: 'Pulse', desc: 'A personal trends radar. It watches the web all day and emails me the signal worth acting on each morning.', chips: ['PWA', 'Cron', 'Resend'], url: 'https://trends.neilb.me', label: 'trends.neilb.me' },
  { name: 'Hop', desc: 'A link shortener with teeth. Real-time analytics, web push, a PWA, and a Chrome extension.', chips: ['Edge', 'Web Push', 'Extension'], url: 'https://links.busqueneil.com', label: 'links.busqueneil.com' },
  { name: 'Prism', desc: 'A Mac browser for people with ten logins. Separate profiles, an ad blocker, and a built-in AI panel.', chips: ['Electron', 'Chromium', 'AI panel'], url: null, label: 'macOS desktop app' },
  { name: 'Tandem', desc: 'A private app for two. Shared habits, letters, games, and watch parties, all in one quiet hub.', chips: ['PWA', 'Supabase', 'Realtime'], url: 'https://hub.yengandneil.site', label: 'hub.yengandneil.site' },
  { name: 'Play Together', desc: 'Watch anything together. One-to-one video calls that share tab audio and stay perfectly in sync.', chips: ['WebRTC', 'TURN', 'Extension'], url: 'https://watch.yengandneil.site', label: 'watch.yengandneil.site' },
];

const caps = [
  { t: 'Marketing & growth', d: 'SEO, paid search, and funnels that turn clicks into customers.' },
  { t: 'Landing pages & web', d: 'Fast, clean pages built to convert, not just to look nice.' },
  { t: 'CRM & GoHighLevel', d: 'Pipelines and follow-up so leads stop slipping through the cracks.' },
  { t: 'Automation', d: 'Zapier and n8n flows that quietly handle the repetitive work.' },
  { t: 'Design & brand', d: 'A graphic-design background, so the work looks the part too.' },
  { t: 'AI agents & systems', d: 'Assistants, SDRs, and copilots on Claude that actually do the job.' },
  { t: 'Web apps & PWAs', d: 'Full products, from a blank file to live, usually in days.' },
  { t: 'Built in Claude Code', d: 'My daily driver. It is how one person ships all of the above.' },
];

const life = [
  { t: 'Devotion', s: 'keeps me grounded, every morning' },
  { t: 'The gym', s: 'alternate days, rest day is important' },
  { t: 'A call with my wife', s: 'the best part of the day' },
  { t: 'Building apps and AI agents', s: 'usually in Claude Code' },
  { t: 'Reading books', s: 'a few going at once' },
  { t: 'Travel', s: 'usually back to the Philippines' },
];

const pad = (n: number) => String(n + 1).padStart(2, '0');
const PLAY = '<svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>';
---
<Base
  title="Neil Busque — AI Engineer & Automation Builder"
  description="I'm Neil Busque, an AI engineer in New Jersey. I build AI agents, automations, and web apps, and help companies rank in AI search and SEO. Open to work."
  canonical="https://busqueneil.com/"
  ogType="profile"
  ogImage="https://busqueneil.com/assets/art/hero.png"
  dark
>
  <Fragment slot="head">
    <Schema />
  </Fragment>

  <div class="home-v4">
    <!-- nav -->
    <header class="nav">
      <div class="nav-inner">
        <a class="brand" href="/">busqueneil</a>
        <nav class="nav-links">
          <a href="#work" class="nav-hide">Work</a>
          <a href="#about" class="nav-hide">About</a>
          <a class="nav-cta" href="#hire">Hire me</a>
        </nav>
      </div>
    </header>

    <!-- hero -->
    <section class="hero">
      <div class="hero-art">
        <img src="/assets/art/hero.png" alt="" width="2560" height="1440" fetchpriority="high" />
      </div>
      <div class="hero-services">
        <span>AI Agents</span>
        <span>Automation</span>
        <span>Web Apps</span>
        <span>Marketing</span>
      </div>
      <div class="hero-inner">
        <div class="hero-copy">
          <p class="label hero-eyebrow"><span class="n">●</span> Open to work · New Jersey</p>
          <h1 class="display">I help you build with AI.<br /><span class="muted">And the marketing and systems around it.</span></h1>
          <p class="hero-sub">
            Need a marketer who can code, an engineer who gets growth, or someone to
            own your whole AI and automation stack? That's me. Let's build something
            together, or just have a chat.
          </p>
          <div class="hero-actions">
            <a class="btn primary" href="#hire">Hire me <span class="ico">→</span></a>
            <a class="btn ghost" href="#work">See the work</a>
          </div>
        </div>
      </div>
    </section>

    <!-- tech marquee -->
    <div class="marquee" aria-hidden="true">
      <div class="marquee-track">
        {[...TECH, ...TECH].map((t) => <span class="mq">{t}</span>)}
      </div>
    </div>

    <!-- about -->
    <div class="rule"></div>
    <section class="section" id="about">
      <div class="shell">
        <p class="label sec-label reveal"><span class="n">01</span> &nbsp;About</p>
        <h2 class="statement reveal">I've followed the interesting work wherever it went. <span class="muted">Right now, it's AI.</span></h2>
        <div class="bio-grid reveal">
          <img class="bio-portrait" src="/assets/art/headshot.png" width="600" height="750" alt="Neil Busque" loading="lazy" />
          <div class="bio-body">
            <p>
              I studied IT, then got pulled into graphic design, which led me into
              web development. From there it was funnels and landing pages, then
              GoHighLevel, then automation with Zapier and n8n. Every couple of
              years the interesting work moved somewhere new, and I followed it.
            </p>
            <p>
              Now we're in the AI era, and I'm all in. I spend most of my day in
              Claude Code, and it has let me build things that used to need a whole
              team: full apps, AI agents, and automations, usually in days.
            </p>
            <p>
              I build in public and ship something most weeks. I'm based in New
              Jersey, and I'm always making something.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- capabilities -->
    <div class="rule"></div>
    <section class="section" id="capabilities">
      <div class="shell">
        <p class="label sec-label reveal"><span class="n">02</span> &nbsp;How I can help</p>
        <h2 class="statement reveal" style="font-size:clamp(26px,3.8vw,46px);max-width:20ch">From your marketing to your AI agents, I can probably help.</h2>
        <div class="caps-grid reveal" style="margin-top:44px">
          {caps.map((c, i) => (
            <div class="cap-card">
              <span class="ci">{pad(i)}</span>
              <h3>{c.t}</h3>
              <p>{c.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- work -->
    <div class="rule"></div>
    <section class="section" id="work">
      <div class="shell">
        <div class="sec-head reveal">
          <div>
            <p class="label"><span class="n">03</span> &nbsp;Projects</p>
            <h2>Some projects.</h2>
          </div>
          <p class="lede">Real, live software I designed and built. Video walkthroughs coming soon.</p>
        </div>
        <div class="work-grid reveal">
          {projects.map((p, i) => (
            <div class="work-card">
              <div class="work-media">
                <span class="play" set:html={PLAY}></span>
                <span class="ph">Demo soon</span>
              </div>
              <div class="top">
                <span class="pname">{p.name}</span>
                <span class="idx">{pad(i)}</span>
              </div>
              <p class="pdesc">{p.desc}</p>
              <div class="chips">{p.chips.map((c) => <span class="chip">{c}</span>)}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- life -->
    <div class="rule"></div>
    <section class="section" id="life">
      <div class="shell">
        <p class="label sec-label reveal"><span class="n">04</span> &nbsp;Outside the work</p>
        <div class="life-grid reveal">
          <div>
            <h2>How I spend my time.</h2>
            <p class="life-note">
              My wife is still in the Philippines, so I go back and forth more than
              most. The goal is simple: bring her and our cat, <strong>Hiro</strong>,
              home to the US.
            </p>
          </div>
          <ul class="life-list">
            {life.map((l, i) => (
              <li><span class="k">{pad(i)}</span><span>{l.t} <span class="sub">· {l.s}</span></span></li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- hire -->
    <div class="rule"></div>
    <section class="section hire-band" id="hire">
      <img class="hire-art" src="/assets/art/terrain.png" alt="" loading="lazy" />
      <div class="shell">
        <div class="hire reveal">
          <p class="label" style="justify-content:center"><span class="n">05</span> &nbsp;Open for work</p>
          <h2>Looking for someone who can do all of it?</h2>
          <p>
            Whether you're hiring for a role or just need something built, I can
            help. Full-time, fractional, or a one-off project, bring me in to own
            the part where marketing, automation, and AI come together. Or just say
            hi.
          </p>
          <div class="roles">
            <span class="role">Fractional CTO</span>
            <span class="role">Head of AI</span>
            <span class="role">AI Systems Architect</span>
            <span class="role">Growth / Marketing Lead</span>
            <span class="role">Automation Engineer</span>
          </div>
          <div class="hire-actions">
            <a class="btn primary" href="mailto:busqueneil@gmail.com">Email me <span class="ico">→</span></a>
            <a class="btn ghost" href="https://www.linkedin.com/in/neilbusque/" rel="me noopener" target="_blank">LinkedIn</a>
            <a class="btn ghost" href="/resume.pdf">Resume</a>
          </div>
        </div>
      </div>
    </section>

    <!-- talk -->
    <div class="rule"></div>
    <section class="section" id="talk">
      <div class="shell">
        <div class="talk reveal">
          <div class="l">
            <h2>Or let's just talk.</h2>
            <p>Skip the form. Hop on a quick video call and let's see how I can help.</p>
          </div>
          <a class="btn primary" href="https://talk.busqueneil.com" rel="noopener" target="_blank">Start a live call <span class="ico">→</span></a>
        </div>
      </div>
    </section>

    <!-- footer -->
    <footer class="v4-footer">
      <div class="fin">
        <div class="ftop">
          <a class="fbrand" href="/">busqueneil</a>
          <div class="flinks">
            <a href="#work">Work</a>
            <a href="/about">About</a>
            <a href="/resume.pdf">Resume</a>
            <a href="mailto:busqueneil@gmail.com">Email</a>
            <a href="https://www.linkedin.com/in/neilbusque/" rel="me noopener" target="_blank">LinkedIn</a>
          </div>
        </div>
        <div class="colophon">Built in public · New Jersey · © 2026 Neil Busque</div>
      </div>
    </footer>

    <!-- floating voice agent -->
    <VoiceWidget client:load />
  </div>

</Base>
