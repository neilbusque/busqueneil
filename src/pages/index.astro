---
import Site from '../layouts/Site.astro';
import Schema from '../components/Schema.astro';
import FeedEntry from '../components/FeedEntry.astro';
import { getFeed, setPublicCache } from '../lib/posts';

const { posts, hasMore } = await getFeed({ request: Astro.request, cookies: Astro.cookies });
setPublicCache(Astro.response.headers);
---
<Site
  title="Neil Busque — everything I build, as I build it"
  description="Neil Busque's working notebook in public: web apps, AI agents, and automations, posted as they happen. Based in Elizabeth, NJ. Open to work and projects."
  canonical="https://busqueneil.com/"
  ogType="profile"
  active="feed"
>
  <Fragment slot="head">
    <Schema />
  </Fragment>

  <section class="hero">
    <div class="kicker">A working notebook, in public</div>
    <h1>Everything I build, <em>as I build it.</em></h1>
    <p>
      I am Neil. I build web apps, AI agents, and automations. No polish, no
      postmortems written months later. The feed below is the actual log of the work.
    </p>
    <span class="status-pill"><span class="dot"></span>Open to work and projects</span>
  </section>

  <section class="feed">
    {posts.length === 0 ? (
      <p style="padding: 30px 0; color: var(--muted);">
        The feed is warming up. First posts land here soon.
      </p>
    ) : (
      posts.map((post) => <FeedEntry post={post} />)
    )}
    {hasMore && (
      <nav class="pager">
        <span></span>
        <a href="/posts?page=2">Older posts →</a>
      </nav>
    )}
  </section>
</Site>
