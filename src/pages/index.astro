---
import Base from '../layouts/Base.astro';
import Schema from '../components/Schema.astro';
import { setPublicCache } from '../lib/posts';
import '../styles/home.css';

const TECH = [
  'Claude Code', 'Next.js', 'Astro', 'React', 'TypeScript', 'Tailwind', 'Supabase',
  'Vercel', 'Cloudflare', 'n8n', 'Zapier', 'GoHighLevel', 'OpenRouter', 'Stripe',
  'Resend', 'Three.js', 'WebRTC', 'Electron', 'PostgreSQL', 'Python', 'Node.js',
];

setPublicCache(Astro.response.headers);

/* Build timelines below come from git history (first commit -> ship commit),
   mined 2026-07-03. Do not embellish these numbers. */
const featured = [
  {
    name: 'Orbit', built: 'built in 2 days',
    desc: 'A simple AI-powered CRM. Pipelines, a shared inbox, billing, and an assistant that drafts replies and books calls. Now at v2.5 after 1,600+ commits.',
    chips: ['Next.js', 'Supabase', 'AI agent'],
    url: 'https://www.inorbit.one', label: 'inorbit.one',
    img: '/assets/work/orbit.webp', alt: 'Orbit CRM marketing site with product dashboard',
  },
  {
    name: 'Otto', built: 'built in a day',
    desc: 'An autonomous command center. A CRM whose AI reads my email, follows up, and moves deals while I am away.',
    chips: ['Next 14', 'Claude', 'Gmail API'],
    url: 'https://otto-neilbusque.vercel.app', label: 'otto-neilbusque.vercel.app',
    img: '/assets/work/otto.webp', alt: 'Otto command center chat interface',
  },
  {
    name: 'Hop', built: 'built in a day',
    desc: 'A link shortener with teeth. Real-time click analytics, web push, a PWA, and a Chrome extension.',
    chips: ['Edge', 'Web Push', 'Extension'],
    url: 'https://links.busqueneil.com', label: 'links.busqueneil.com',
    img: '/assets/work/hop.webp', alt: 'Hop dashboard with live click analytics',
  },
  {
    name: 'Tandem', built: 'v1 in a day',
    desc: 'A private app for two. Shared habits, letters, games, and watch parties, all in one quiet hub.',
    chips: ['PWA', 'Supabase', 'Realtime'],
    url: 'https://tandem.yengandneil.site', label: 'tandem.yengandneil.site',
    img: '/assets/work/tandem.webp', alt: 'Tandem couples app landing page',
  },
  {
    name: 'Play Together', built: 'built in a day',
    desc: 'Watch anything together. One-to-one video calls that share tab audio and stay perfectly in sync.',
    chips: ['WebRTC', 'TURN', 'Extension'],
    url: 'https://watch.yengandneil.site', label: 'watch.yengandneil.site',
    img: '/assets/work/play-together.webp', alt: 'Watch Together room creation screen',
  },
];

const more = [
  {
    name: 'Magus', built: 'v1 in 3 days',
    desc: 'Cold email plus an AI SDR. It writes, sends, calls, and books, then hands you a calendar that fills itself.',
    chips: ['Supabase', 'Vapi', 'Cal.com'],
    url: 'https://magus.neilb.me', label: 'magus.neilb.me',
  },
  {
    name: 'Pulse', built: 'built in a day',
    desc: 'A personal trends radar. It watches the web all day and emails me the signal worth acting on each morning.',
    chips: ['PWA', 'Cron', 'Resend'],
    url: 'https://trends.neilb.me', label: 'trends.neilb.me',
  },
  {
    name: 'Prism', built: 'built in a day',
    desc: 'A Mac browser for people with ten logins. Separate profiles, an ad blocker, and a built-in AI panel.',
    chips: ['Electron', 'Chromium', 'AI panel'],
    url: null, label: 'macOS desktop app',
  },
];

const caps = [
  { t: 'Marketing & growth', d: 'SEO, paid search, and funnels that turn clicks into customers.' },
  { t: 'Landing pages & web', d: 'Fast, clean pages built to convert, not just to look nice.' },
  { t: 'CRM & GoHighLevel', d: 'Pipelines and follow-up so leads stop slipping through the cracks.' },
  { t: 'Automation', d: 'Zapier and n8n flows that quietly handle the repetitive work.' },
  { t: 'Design & brand', d: 'A graphic-design background, so the work looks the part too.' },
  { t: 'AI agents & systems', d: 'Assistants, SDRs, and copilots on Claude that actually do the job.' },
  { t: 'Web apps & PWAs', d: 'Full products, from a blank file to live, usually in days.' },
  { t: 'Built in Claude Code', d: 'My daily driver. It is how one person ships all of the above.' },
];

const pad = (n: number) => String(n + 1).padStart(2, '0');
---
<Base
  title="Neil Busque — AI Engineer & Automation Builder"
  description="AI engineer and automation builder available fractional or project-based. I build agents, funnels, and the systems around them, usually solo, usually fast. Based in New Jersey."
  canonical="https://busqueneil.com/"
  ogType="profile"
  ogImage="https://busqueneil.com/assets/og-v5.png"
  dark
>
  <Fragment slot="head">
    <link rel="preload" as="image" href="/assets/art/hero-poster.webp" fetchpriority="high" />
    <Schema />
  </Fragment>

  <div class="home-v4">
    <!-- nav -->
    <header class="nav">
      <div class="nav-inner">
        <a class="brand" href="/">busqueneil</a>
        <nav class="nav-links">
          <a href="#work" class="nav-hide">Work</a>
          <a href="#about" class="nav-hide">About</a>
          <a class="nav-cta" href="#contact">Get in touch</a>
        </nav>
      </div>
    </header>

    <!-- hero -->
    <section class="hero">
      <div class="hero-art">
        <img src="/assets/art/hero-poster.webp" alt="" width="1920" height="1080" fetchpriority="high" />
        <video id="heroVideo" muted loop playsinline preload="none" poster="/assets/art/hero-poster.webp" aria-hidden="true">
          <source src="/assets/art/hero-loop.webm" type="video/webm" />
          <source src="/assets/art/hero-loop.mp4" type="video/mp4" />
        </video>
      </div>
      <div class="hero-inner">
        <div class="hero-copy">
          <p class="label hero-eyebrow"><span class="n">●</span> Open to work · New Jersey</p>
          <h1 class="display">One person to own your AI, automation, and growth stack.<span class="accent">Ships in days, not quarters.</span></h1>
          <p class="hero-sub">
            Fractional AI engineer and marketer. I build agents, automations, and
            the funnels around them, usually solo, usually fast.
          </p>
          <div class="hero-actions">
            <div>
              <a class="btn primary" href="#contact">Book a free call <span class="ico">→</span></a>
              <p class="cta-note">20 minutes. No prep needed.</p>
            </div>
            <a class="btn ghost" href="#work">See the work</a>
          </div>
          <p class="hero-proof"><span class="tick">✓</span> 8 products below. Every v1 shipped in 3 days or less.</p>
        </div>
      </div>
    </section>

    <!-- about -->
    <div class="rule"></div>
    <section class="section" id="about">
      <div class="shell">
        <p class="label sec-label reveal"><span class="n">01</span> &nbsp;About</p>
        <h2 class="statement reveal">I've followed the interesting work wherever it went. <span class="muted">Right now, it's AI.</span></h2>
        <div class="bio-grid reveal">
          <img class="bio-portrait" src="/assets/art/headshot.png" width="600" height="750" alt="Neil Busque" loading="lazy" />
          <div class="bio-body">
            <p>
              I studied IT, then got pulled into graphic design, which led me into
              web development. From there it was funnels and landing pages, then
              GoHighLevel, then automation with Zapier and n8n. Every couple of
              years the interesting work moved somewhere new, and I followed it.
            </p>
            <p>
              Now we're in the AI era, and I'm all in. I spend most of my day in
              Claude Code, and it has let me build things that used to need a whole
              team: full apps, AI agents, and automations, usually in days.
            </p>
            <p>
              I build in public and ship something most weeks. I'm based in New
              Jersey, and I'm always making something.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- tech marquee -->
    <div class="marquee" aria-hidden="true">
      <div class="marquee-track">
        {[...TECH, ...TECH].map((t) => <span class="mq">{t}</span>)}
      </div>
    </div>

    <!-- capabilities -->
    <section class="section" id="capabilities">
      <div class="shell">
        <p class="label sec-label reveal"><span class="n">02</span> &nbsp;How I can help</p>
        <h2 class="statement reveal" style="font-size:clamp(26px,3.8vw,46px);max-width:20ch">From your marketing to your AI agents, I can probably help.</h2>
        <div class="caps-grid reveal" style="margin-top:44px">
          {caps.map((c, i) => (
            <div class="cap-card">
              <span class="ci">{pad(i)}</span>
              <h3>{c.t}</h3>
              <p>{c.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- work -->
    <div class="rule"></div>
    <section class="section" id="work">
      <div class="shell">
        <div class="sec-head reveal">
          <div>
            <p class="label"><span class="n">03</span> &nbsp;Projects</p>
            <h2>Real products, live now.</h2>
          </div>
          <p class="lede">Designed, built, and shipped solo. Build times below come straight from git history.</p>
        </div>
        <div class="work-grid reveal">
          {featured.map((p) => (
            <a class="work-card" href={p.url} target="_blank" rel="noopener">
              <div class="work-media">
                <img src={p.img} alt={p.alt} width="1280" height="800" loading="lazy" />
              </div>
              <div class="top">
                <span class="pname">{p.name}</span>
                <span class="built">{p.built}</span>
              </div>
              <p class="pdesc">{p.desc}</p>
              <div class="chips">{p.chips.map((c) => <span class="chip">{c}</span>)}</div>
              <p class="liveurl"><span class="live-dot"></span>{p.label}</p>
            </a>
          ))}
          {more.map((p) =>
            p.url ? (
              <a class="work-card compact" href={p.url} target="_blank" rel="noopener">
                <div class="top">
                  <span class="pname">{p.name}</span>
                  <span class="built">{p.built}</span>
                </div>
                <p class="pdesc">{p.desc}</p>
                <div class="chips">{p.chips.map((c) => <span class="chip">{c}</span>)}</div>
                <p class="liveurl"><span class="live-dot"></span>{p.label}</p>
              </a>
            ) : (
              <div class="work-card compact">
                <div class="top">
                  <span class="pname">{p.name}</span>
                  <span class="built">{p.built}</span>
                </div>
                <p class="pdesc">{p.desc}</p>
                <div class="chips">{p.chips.map((c) => <span class="chip">{c}</span>)}</div>
                <p class="liveurl">{p.label}</p>
              </div>
            )
          )}
          <a class="work-card compact" href="/feed">
            <div class="top">
              <span class="pname">More builds</span>
            </div>
            <p class="pdesc">These 8 are the highlights. The rest ships to the build log as it happens, most weeks.</p>
            <p class="liveurl">busqueneil.com/feed →</p>
          </a>
        </div>
      </div>
    </section>

    <!-- risk reversal -->
    <div class="rule"></div>
    <section class="section">
      <div class="shell">
        <div class="assure reveal">
          <p class="label" style="justify-content:center"><span class="n">✳</span> &nbsp;No pressure</p>
          <h2>Not sure I'm the right fit?</h2>
          <p>Let's talk for 20 minutes anyway. If I can't help, I'll tell you who can. No pitch, no follow-up sequence, no hard feelings.</p>
          <a class="btn ghost" href="#contact">Get in touch</a>
        </div>
      </div>
    </section>

    <!-- contact / open for work -->
    <div class="rule"></div>
    <section class="section hire-band" id="contact">
      <img class="hire-art" src="/assets/art/terrain.png" alt="" loading="lazy" />
      <div class="shell">
        <div class="contact-grid reveal">
          <div class="contact-copy">
            <p class="label"><span class="n">04</span> &nbsp;Open for work</p>
            <h2>Tell me what you need.</h2>
            <p class="pitch">
              Full-time, fractional, or a one-off project. Bring me in to own the
              part where marketing, automation, and AI come together.
            </p>
            <div class="roles">
              <span class="role">Fractional CTO</span>
              <span class="role">Head of AI</span>
              <span class="role">AI Systems Architect</span>
              <span class="role">Growth / Marketing Lead</span>
              <span class="role">Automation Engineer</span>
            </div>
            <div class="alt-contact">
              <a href="mailto:busqueneil@gmail.com">busqueneil@gmail.com</a>
              <a href="https://www.linkedin.com/in/neilbusque/" rel="me noopener" target="_blank">LinkedIn</a>
              <a href="/resume.pdf">Resume</a>
              <a href="https://talk.busqueneil.com" rel="noopener" target="_blank">Around right now? Start a live call</a>
            </div>
          </div>
          <div class="lead-card">
            <form id="contactForm" novalidate>
              <h3 class="lc-title">Book a free call</h3>
              <p class="lc-sub">Tell me what you need and I'll reply within a day with times. 20 minutes. No prep needed.</p>
              <p class="hp" aria-hidden="true"><label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label></p>
              <div class="field">
                <label for="cf-name">Name</label>
                <input type="text" id="cf-name" name="name" required autocomplete="name" placeholder="Your name" />
              </div>
              <div class="field">
                <label for="cf-email">Work email</label>
                <input type="email" id="cf-email" name="email" required autocomplete="email" placeholder="you@company.com" />
              </div>
              <div class="field">
                <label for="cf-need">What do you need most?</label>
                <select id="cf-need" name="need" required>
                  <option value="AI agents">AI agents</option>
                  <option value="Automation">Automation</option>
                  <option value="Marketing">Marketing</option>
                  <option value="Web app">Web app</option>
                  <option value="Not sure yet" selected>Not sure yet</option>
                </select>
              </div>
              <button class="btn primary" type="submit">Get in touch <span class="ico">→</span></button>
              <p class="form-note">No newsletter, no sequence. Just a reply from me.</p>
            </form>
            <div id="formSuccess" class="form-success" hidden>
              <div class="fs-ico">✓</div>
              <h3>Got it.</h3>
              <p>I'll reply within a day with times for a call. Talk soon.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- footer -->
    <footer class="v4-footer">
      <div class="fin">
        <div class="ftop">
          <a class="fbrand" href="/">busqueneil</a>
          <div class="flinks">
            <a href="#work">Work</a>
            <a href="/about">About</a>
            <a href="/resume.pdf">Resume</a>
            <a href="mailto:busqueneil@gmail.com">Email</a>
            <a href="https://www.linkedin.com/in/neilbusque/" rel="me noopener" target="_blank">LinkedIn</a>
          </div>
        </div>
        <div class="colophon">Built in public · New Jersey · © 2026 Neil Busque</div>
      </div>
    </footer>
  </div>

  <script is:inline>
    // Hero video: start only after full page load, skip on reduced motion / Save-Data.
    (function () {
      var v = document.getElementById('heroVideo');
      if (!v) return;
      var conn = navigator.connection || {};
      if (matchMedia('(prefers-reduced-motion: reduce)').matches || conn.saveData) { v.remove(); return; }
      var start = function () {
        v.addEventListener('playing', function () { v.classList.add('playing'); }, { once: true });
        v.play().catch(function () { /* poster stays */ });
      };
      if (document.readyState === 'complete') start();
      else window.addEventListener('load', start, { once: true });
      v.addEventListener('error', function () { v.remove(); }, true);
    })();

    // Contact form -> Orbit form-lead edge function (same contract as /help funnel).
    (function () {
      var form = document.getElementById('contactForm');
      if (!form) return;
      var ENDPOINT = (location.hostname === 'localhost' || location.hostname === '127.0.0.1')
        ? 'https://cubglfkgnjvlwelkmnbh.supabase.co/functions/v1/form-lead'
        : '/api/form-lead';
      var ANON = 'sb_publishable_vxcbGxMEjdCxYm77sOwldg_hkWcIRbO';

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        if (!form.reportValidity()) return;
        var btn = form.querySelector('[type="submit"]');
        var old = form.querySelector('.form-msg'); if (old) old.remove();

        var data = { form: 'home-contact' };
        new FormData(form).forEach(function (value, key) {
          if (key === 'bot-field') { data.bot_field = value; return; }
          data[key] = value;
        });

        btn.disabled = true; btn.firstChild.textContent = 'Sending... ';
        fetch(ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', apikey: ANON, Authorization: 'Bearer ' + ANON },
          body: JSON.stringify(data),
        })
          .then(function (r) { return r.json().catch(function () { return {}; }).then(function (b) { return { ok: r.ok && b && b.ok }; }); })
          .then(function (res) {
            if (!res.ok) throw new Error('submit failed');
            form.hidden = true;
            document.getElementById('formSuccess').hidden = false;
          })
          .catch(function () {
            btn.disabled = false; btn.firstChild.textContent = 'Get in touch ';
            var m = document.createElement('p');
            m.className = 'form-msg err';
            m.innerHTML = 'Something went wrong. Email me instead: <a href="mailto:busqueneil@gmail.com">busqueneil@gmail.com</a>';
            form.appendChild(m);
          });
      });
    })();
  </script>
</Base>
