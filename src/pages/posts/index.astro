---
import Site from '../../layouts/Site.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FeedEntry from '../../components/FeedEntry.astro';
import { getFeed, setPublicCache } from '../../lib/posts';

const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') ?? '1', 10) || 1);
const tag = Astro.url.searchParams.get('tag') ?? undefined;

const { posts, hasMore } = await getFeed(
  { request: Astro.request, cookies: Astro.cookies },
  { page, tag }
);
setPublicCache(Astro.response.headers);

const titleSuffix = tag ? ` tagged "${tag}"` : '';
---
<Site
  title={`Writing${titleSuffix} — Neil Busque`}
  description="Archive of everything Neil Busque has posted: status updates, articles, and shipped projects, in public as it happens."
  canonical="https://busqueneil.com/posts"
  active="writing"
  noindex={page > 1 || Boolean(tag)}
>
  <Fragment slot="head">
    <Breadcrumb items={[
      { name: 'Home', url: 'https://busqueneil.com/' },
      { name: 'Writing', url: 'https://busqueneil.com/posts' },
    ]} />
  </Fragment>

  <header class="page-head">
    <p class="eyebrow"><span class="idx">∗</span> The archive</p>
    {tag ? (
      <h1>Everything tagged <span class="accent">{tag}</span>.</h1>
    ) : (
      <h1>Everything, <span class="accent">written down</span>.</h1>
    )}
    <p class="lede">Statuses, articles, and project notes. The full build log, newest first.</p>
  </header>

  <section class="feed">
    {posts.length === 0 ? (
      <p class="empty">Nothing here yet.</p>
    ) : (
      posts.map((post) => <FeedEntry post={post} />)
    )}
    <nav class="pager">
      {page > 1 ? (
        <a href={`/posts?page=${page - 1}${tag ? `&tag=${tag}` : ''}`}>← Newer</a>
      ) : (
        <span></span>
      )}
      {hasMore && <a href={`/posts?page=${page + 1}${tag ? `&tag=${tag}` : ''}`}>Older →</a>}
    </nav>
  </section>
</Site>
