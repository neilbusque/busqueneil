---
import Site from '../../layouts/Site.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getPostBySlug, setPublicCache } from '../../lib/posts';
import { publicImageUrl } from '../../lib/supabase';
import { formatDate, readingTime } from '../../lib/format';
import { deriveExcerpt } from '../../lib/markdown';

const { slug } = Astro.params;
const post = slug
  ? await getPostBySlug({ request: Astro.request, cookies: Astro.cookies }, slug)
  : null;

if (!post) {
  return new Response(null, { status: 404 });
}
setPublicCache(Astro.response.headers);

const title = post.title ?? deriveExcerpt(post.body_md, 60);
const description = post.excerpt ?? deriveExcerpt(post.body_md);
const canonical = `https://busqueneil.com/posts/${post.slug}`;
const ogImage = `https://busqueneil.com/og/${post.slug}.png?v=${encodeURIComponent(post.updated_at)}`;

const TAG_LABEL: Record<string, string> = {
  status: 'Status',
  article: 'Article',
  project: 'Project',
  now: 'Now',
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': post.type === 'project' ? 'CreativeWork' : 'BlogPosting',
  headline: title,
  description,
  url: canonical,
  datePublished: post.published_at,
  dateModified: post.updated_at,
  image: post.images?.[0] ? publicImageUrl(post.images[0].path) : ogImage,
  author: { '@id': 'https://busqueneil.com/#person' },
  publisher: { '@id': 'https://busqueneil.com/#person' },
  mainEntityOfPage: canonical,
  ...(post.tags.length ? { keywords: post.tags.join(', ') } : {}),
};
---
<Site
  title={`${title} — Neil Busque`}
  description={description}
  canonical={canonical}
  ogType="article"
  ogImage={ogImage}
  active="writing"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <Breadcrumb items={[
      { name: 'Home', url: 'https://busqueneil.com/' },
      { name: 'Writing', url: 'https://busqueneil.com/posts' },
      { name: title, url: canonical },
    ]} />
  </Fragment>

  <article class="article-page">
    <p class="eyebrow"><span class="idx">∗</span> {TAG_LABEL[post.type] ?? post.type}</p>
    {post.title && <h1>{post.title}</h1>}
    <div class="byline">
      <span>{formatDate(post.published_at)}</span>
      {post.type === 'article' && <span>{readingTime(post.body_md)}</span>}
      <span>Neil Busque</span>
    </div>

    {post.type === 'project' && post.project_meta && (
      <div class="project-meta">
        {post.project_meta.stack?.length && (
          <span>Built with {post.project_meta.stack.join(' · ')}</span>
        )}
        {post.project_meta.live_url && (
          <a href={post.project_meta.live_url} rel="noopener">Live app ↗</a>
        )}
        {post.project_meta.repo_url && (
          <a href={post.project_meta.repo_url} rel="noopener">Code ↗</a>
        )}
      </div>
    )}

    <div class="prose" set:html={post.body_html} />

    {post.images?.length > 0 && !post.body_md.includes('![') && (
      <div class="prose">
        {post.images.map((img) => (
          <img
            src={publicImageUrl(img.path)}
            alt={img.alt ?? ''}
            width={img.width}
            height={img.height}
            loading="lazy"
          />
        ))}
      </div>
    )}

    <p style="margin-top: 44px; padding-top: 24px; border-top: 1px solid var(--rule);">
      <a class="more" href="/">← Back to the feed</a>
    </p>
  </article>
</Site>
