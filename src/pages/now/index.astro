---
import Site from '../../layouts/Site.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getNow, setPublicCache } from '../../lib/posts';
import { formatDate } from '../../lib/format';

const { current, archive } = await getNow({ request: Astro.request, cookies: Astro.cookies });
setPublicCache(Astro.response.headers);
---
<Site
  title="Now — Neil Busque"
  description="What Neil Busque is doing right now: where he is, what he is building, what he is thinking about. Updated when life shifts."
  canonical="https://busqueneil.com/now/"
  active="now"
>
  <Fragment slot="head">
    <Breadcrumb items={[
      { name: 'Home', url: 'https://busqueneil.com/' },
      { name: 'Now', url: 'https://busqueneil.com/now/' },
    ]} />
  </Fragment>

  <header class="page-head">
    <p class="eyebrow"><span class="idx">●</span> Now</p>
    <h1>What I'm <span class="accent">up to</span>.</h1>
    <p class="lede">A snapshot of where my head is and what I'm working on. I update it when life shifts. Inspired by Derek Sivers' /now idea.</p>
    {current?.published_at && (
      <p class="updated">Updated {formatDate(current.published_at)}</p>
    )}
  </header>

  <section class="feed">
    {current ? (
      <article class="article-page" style="padding: 8px 0 48px;">
        {current.title && <h2 style="font-size: clamp(26px,3.4vw,40px); max-width:24ch; margin-bottom:18px;">{current.title}</h2>}
        <div class="prose" set:html={current.body_html} />
      </article>
    ) : (
      <p class="empty">The first /now entry lands here soon.</p>
    )}

    <div class="section">
      <p class="eyebrow"><span class="idx">∗</span> Archive <span class="line"></span></p>
      {archive.length === 0 ? (
        <p class="empty">Past Now states will live here as time passes.</p>
      ) : (
        <div class="feed" style="margin-top:24px;">
          {archive.map((post) => (
            <article class="entry">
              <div class="when">{formatDate(post.published_at)}</div>
              <div class="body">
                {post.title && <h3><a href={`/posts/${post.slug}`}>{post.title}</a></h3>}
                <div class="prose" set:html={post.body_html} />
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</Site>
