      },
    },
    {
      '@type': 'Question',
      name: 'What is an MCP server?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'An MCP server is a small program that exposes a specific tool or data source to an AI model. For example, an MCP server can wrap a database, a Notion workspace, or a file system. The AI (the MCP client) talks to the server over the protocol, and the server handles the real work of fetching data or running an action.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is MCP open source?',
