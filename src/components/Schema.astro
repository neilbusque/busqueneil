---
// Person + WebSite + ProfilePage + FAQPage JSON-LD for the homepage.
// Positioning kept current: independent operator & builder, open to work.

const person = {
  '@type': 'Person',
  '@id': 'https://busqueneil.com/#person',
  name: 'Neil Busque',
  givenName: 'Neil',
  familyName: 'Busque',
  url: 'https://busqueneil.com/',
  image: 'https://busqueneil.com/assets/logo/icon-512.png',
  jobTitle: 'Digital marketing & automation consultant',
  description:
    'Independent operator and builder based in Elizabeth, New Jersey. Builds web apps, AI agents, and automation systems, and works with businesses on digital marketing, SEO, paid search, funnels, and CRM. Documents everything he builds, in public, at busqueneil.com. Open to full-time roles and project work.',
  email: 'mailto:busqueneil@gmail.com',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Elizabeth',
    addressRegion: 'NJ',
    addressCountry: 'US',
  },
  hasOccupation: {
    '@type': 'Occupation',
    name: 'Digital marketing & automation consultant',
    occupationLocation: { '@type': 'City', name: 'Elizabeth, NJ' },
    skills: 'SEO, paid search, Meta Ads, marketing automation, CRM, n8n, AI agents, web app development',
  },
  alumniOf: {
    '@type': 'CollegeOrUniversity',
    name: 'STI Tagum College',
    address: 'Philippines',
  },
  knowsAbout: [
    'Digital marketing',
    'SEO',
    'Paid search',
    'Meta Ads',
    'Conversion funnels',
    'Marketing automation',
    'AI agents',
    'Workflow automation',
    'n8n',
    'GoHighLevel',
    'CRM',
    'Web app development',
    'Astro',
    'Supabase',
    'Claude Code',
  ],
  sameAs: [
    'https://www.linkedin.com/in/neilbusque',
    'https://github.com/neilbusque',
  ],
};

const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://busqueneil.com/#website',
  url: 'https://busqueneil.com/',
  name: 'Neil Busque',
  description:
    'Neil Busque builds web apps, AI agents, and automations in public. Based in Elizabeth, NJ.',
  inLanguage: 'en-US',
  publisher: { '@id': 'https://busqueneil.com/#person' },
};

const profilePage = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  dateCreated: '2026-05-13',
  dateModified: '2026-06-16',
  mainEntity: person,
};

const faqPage = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Who is Neil Busque?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Neil Busque is an independent operator and builder based in Elizabeth, New Jersey. He builds web apps, AI agents, and automation systems, and works with businesses on digital marketing, SEO, paid search, funnels, and CRM. He documents the work in public on the feed at busqueneil.com.',
      },
    },
    {
      '@type': 'Question',
      name: 'Where is Neil Busque based?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Elizabeth, New Jersey, United States (Eastern Time). He works remote, hybrid, or on-site across the NJ / NYC metro.',
      },
    },
    {
      '@type': 'Question',
      name: 'What does Neil Busque do?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'He builds the systems that turn marketing into revenue: digital marketing and SEO, paid search and Meta Ads, conversion funnels, CRM and marketing automation in tools like GoHighLevel and n8n, AI agents built on Claude Code, and custom web apps and PWAs. He ships fast and posts the work in public at busqueneil.com.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is Neil Busque available for hire?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Neil is open to full-time roles in digital marketing, SEO, paid search, and marketing operations, and to project work such as funnel builds, automation, AI agents, and custom apps. Reach him at busqueneil@gmail.com or on LinkedIn at linkedin.com/in/neilbusque.',
      },
    },
    {
      '@type': 'Question',
      name: 'How can I contact Neil Busque?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Email busqueneil@gmail.com or message him on LinkedIn at linkedin.com/in/neilbusque. The contact widget on busqueneil.com also offers WhatsApp, SMS, and phone options.',
      },
    },
  ],
};
---
<script type="application/ld+json" set:html={JSON.stringify(website)} />
<script type="application/ld+json" set:html={JSON.stringify(profilePage)} />
<script type="application/ld+json" set:html={JSON.stringify(faqPage)} />
